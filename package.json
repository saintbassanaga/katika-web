{
  "name": "katica",
  "version": "1.0.0",
  "packageManager": "yarn@4.13.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --proxy-config proxy.conf.local.json",
    "start:remote": "ng serve --proxy-config proxy.conf.remote.json",
    "build": "npx ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:katica": "node dist/katica/server/server.mjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
